# Resend — transactional email via notify.rootedhealthmember.com
# Get API key from resend.com after DNS is wired
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Supabase — member portal auth and database
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# AWS SES — transactional email via notify.rootedhealthmember.com
# Wire in after DNS validation in AWS SES console
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SES_FROM_EMAIL=notify@rootedhealthmember.com
